{
  "name": "@odds-collector/worker",
  "version": "0.1.0",
  "description": "Cloudflare Worker for automated football odds collection with event-based scheduling, D1 persistence, and R2 storage",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "test": "jest",
    "lint": "eslint src **/**.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "backfill": "ts-node src/scripts/backfill.ts",
    "populate-match-metadata": "ts-node src/scripts/populateMatchMetadata.ts",
    "populate-steam-moves": "ts-node src/scripts/populateSteamMoves.ts"
  },
  "keywords": [
    "sports",
    "betting",
    "odds",
    "api",
    "collection",
    "automation",
    "scheduling",
    "cloudflare",
    "workers",
    "r2",
    "d1",
    "football",
    "soccer"
  ],
  "author": "Benjamin Bours",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251113.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.46.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@odds-collector/shared": "*",
    "@odds-collector/team-normalization": "*"
  }
}
