{
  "name": "odds-collector-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "OddsLab monorepo: odds collector and intelligence dashboard",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:collector": "npm run dev -w @odds-collector/worker",
    "dev:dashboard": "npm run dev -w @odds-collector/dashboard",
    "build": "npm run build --workspaces",
    "build:shared": "npm run build -w @odds-collector/shared",
    "build:collector": "npm run build -w @odds-collector/worker",
    "build:dashboard": "npm run build -w @odds-collector/dashboard",
    "deploy:collector": "npm run deploy -w @odds-collector/worker",
    "deploy:dashboard": "npm run deploy -w @odds-collector/dashboard",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present"
  },
  "author": "Benjamin Bours",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/benjaminbours/odds-collector.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.1",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.46.3"
  }
}
